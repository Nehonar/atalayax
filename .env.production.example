# ── AtalayaX · Producción ─────────────────────────────────────────────────────
# Copia este archivo a .env.production y rellena los valores reales.
# NUNCA subas .env.production a git.

NODE_ENV=production
PORT=4000

# Secreto de sesión — genera uno con:  openssl rand -hex 32
SESSION_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_DE_64_CHARS

# Base de datos (no usada aún, déjala vacía o pon un placeholder)
DATABASE_URL=

# SMTP — déjalo vacío si no usas email todavía
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
